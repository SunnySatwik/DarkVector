APP_NAME=
APP_VERSION=

HOST=
PORT=

DATABASE_URL=postgresql://postgres:<password>@localhost:5432/darkvector

# Isolated test database — must be a SEPARATE database from DATABASE_URL.
# The database name must contain 'test' (e.g. darkvector_test).
# pytest will refuse to start if this points to the same DB as DATABASE_URL.
# Create the test database first: psql -U postgres -c "CREATE DATABASE darkvector_test;"
TEST_DATABASE_URL=postgresql://postgres:<password>@localhost:5432/darkvector_test

LOG_LEVEL=

GEMINI_API_KEY=
USE_LLM=

